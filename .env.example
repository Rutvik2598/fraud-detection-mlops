# Copy to `.env` and fill in. `.env` is gitignored (invariant 8).

# --- Paths ---
# Absolute or repo-relative path to the IEEE-CIS dataset directory.
DATASET_DIR=dataset

# --- MLflow ---
# Local SQLite backend (the file store is deprecated in MLflow >=3 and can't
# host the model registry). Artifacts land in ./mlartifacts. Both gitignored.
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_ARTIFACT_LOCATION=./mlartifacts
MLFLOW_EXPERIMENT=fraud-baseline

# --- Streaming (M2: Redpanda / Kafka API) ---
# Host-facing bootstrap (Redpanda EXTERNAL listener). In-network services use
# redpanda:29092 instead. Replay speed = simulated TransactionDT-seconds per real
# second (0 = as fast as possible).
REDPANDA_BOOTSTRAP=localhost:19092
TRANSACTIONS_TOPIC=transactions
TRANSACTIONS_PARTITIONS=6
FEATURE_CONSUMER_GROUP=fraud-feature-updater
REPLAY_SPEED=3600

# --- Feature store + serving (M3: Feast + FastAPI) ---
# Online store: "redis" (docker-compose, the target) or "sqlite" (local, no Docker).
FEAST_ONLINE_STORE=redis
REDIS_CONNECTION_STRING=localhost:6379
# State is built from transactions up to this time quantile; later txns are the
# "live" stream scored against that state (matches the M1 train/val boundary).
CARD_STATE_CUTOFF_FRACTION=0.8
SERVING_PORT=8001

# --- Feedback loop + retraining (M4: Prefect) ---
# A transaction's label (chargeback) is usable only this many TransactionDT-seconds
# after it occurred. Retraining at clock T may use only labels matured by T.
LABEL_DELAY_SECONDS=604800
# Challengers register here; the champion alias is promoted only on a real win.
FEEDBACK_MODEL_NAME=fraud-detection-feedback
PROMOTION_MARGIN=0.0

# --- Monitoring + drift (M5: Evidently + Prometheus/Grafana) ---
# Dataset drift fires when at least this share of monitored features drift.
DRIFT_SHARE_THRESHOLD=0.3
DRIFT_WINDOW_SIZE=5000
MONITORING_PORT=8003
# Synthetic covariate shift used by `producer --drift` and the drift demo.
DRIFT_AMOUNT_MULTIPLIER=5.0
DRIFT_AMOUNT_SHIFT=200.0

# --- Reproducibility ---
RANDOM_SEED=42
